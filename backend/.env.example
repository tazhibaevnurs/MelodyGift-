# Suno API (sunoapi.org)
SUNO_API_KEY=your_suno_api_key_here
SUNO_API_BASE_URL=https://api.sunoapi.org/api/v1

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Suno polling (Celery task)
SUNO_POLL_INTERVAL_SEC=20
SUNO_POLL_MAX_WAIT_SEC=300
SUNO_DEFAULT_MODEL=V4_5ALL

# Internal refund (worker -> FastAPI)
BACKEND_URL=http://localhost:8000
INTERNAL_SECRET=your_random_secret_for_refund_calls

# Admin dashboard (X-Admin-Secret header)
ADMIN_SECRET=your_admin_secret
